# Spencer's Full Project Ecosystem — Hub & Spoke Layout
# Projects on left/right, shared services in the center

direction: right

vars: {
  svc: "#E8F0FE"
  db: "#E6F4EA"
  ext: "#FFF3E0"
  deploy: "#F3E8FF"
  discord: "#E8EAF6"
}

# ============================================================
# LEFT COLUMN — Insurance AI + Agency Submissions
# ============================================================

col_l: " " {
  grid-columns: 1
  grid-gap: 24
  style.fill: transparent
  style.stroke: transparent

  insurance: Insurance AI Bots {
    style.font-size: 36
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.bold: true
    style.shadow: true
    style.border-radius: 12

    uwbot: Insurance UW Bot {
      link: https://github.com/spencer-life/insurance-uw-bot
      tooltip: "Python + Claude Sonnet 4 + Haiku 4.5, 9 carriers, 545 tests"
      icon: https://icons.terrastruct.com/dev%2Fpython.svg
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Insurance UW Bot\nPython + Claude AI\n9 carriers | 545 tests
    }

    annuity: Annuity Expert AI {
      link: https://github.com/spencer-life/annuity-expert-ai
      tooltip: "Python + FastAPI + Claude Sonnet 4, 19 carriers, 184 tests"
      icon: https://icons.terrastruct.com/dev%2Fpython.svg
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Annuity Expert AI\nPython + FastAPI\n19 carriers | 184 tests
    }
  }

  submissions: Agency Submissions {
    style.font-size: 36
    style.fill: "#FCE4EC"
    style.stroke: "#C62828"
    style.bold: true
    style.shadow: true
    style.border-radius: 12

    diligence: Diligence {
      tooltip: "11 sub-agencies, 4 submission forms"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Diligence\n11 sub-agencies
    }

    reflect: Reflect {
      tooltip: "5 sub-agencies, 1 submission form"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Reflect\n5 sub-agencies
    }
  }
}

# ============================================================
# CENTER — Shared Platform (vertical stack)
# Services ordered to minimize crossing: top services used by
# top projects, bottom services used by bottom projects
# ============================================================

platform: Shared Platform {
  style.font-size: 38
  style.fill: "#F3E8FF"
  style.stroke: "#7C3AED"
  style.bold: true
  style.shadow: true
  style.border-radius: 12
  grid-columns: 1
  grid-gap: 12

  supabase: Supabase {
    tooltip: "6 projects across 2 accounts"
    style.fill: "#E6F4EA"
    style.stroke: "#34A853"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
    label: Supabase — 6 projects | 2 accounts
  }

  railway: Railway {
    tooltip: "10 projects, 8 with active services"
    style.fill: "#EDE7F6"
    style.stroke: "#7C3AED"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    icon: https://icons.terrastruct.com/tech%2F022-server.svg
    label: Railway — 10 projects
  }

  netlify: Netlify {
    tooltip: "23 sites, 2 custom domains"
    style.fill: "#E0F2F1"
    style.stroke: "#00897B"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    label: Netlify — 23 sites
  }

  discord_svc: Discord {
    tooltip: "5+ active bots"
    style.fill: "#E8EAF6"
    style.stroke: "#5865F2"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    label: Discord — 5+ bots
  }

  sheets: Google Sheets {
    tooltip: "4 tracked spreadsheets"
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    label: Google Sheets — 4 trackers
  }

  apps_script: Apps Script {
    tooltip: "2 active deployments"
    style.fill: "#E8F5E9"
    style.stroke: "#43A047"
    style.bold: true
    style.shadow: true
    style.3d: true
    style.border-radius: 8
    label: Apps Script — 2 deployments
  }
}

# ============================================================
# RIGHT COLUMN — Community + WarRoom
# Community on top (connects to top services), WarRoom below
# ============================================================

col_r: " " {
  grid-columns: 1
  grid-gap: 24
  style.fill: transparent
  style.stroke: transparent

  community: Community + Entertainment {
    style.font-size: 36
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.bold: true
    style.shadow: true
    style.border-radius: 12

    nigel: N.I.G.E.L / S.P.A.R.K. {
      link: https://github.com/spencer-life/N.I.G.E.L
      tooltip: "RAG + Claude + Gemini, 8 agents, 12 skills"
      icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: N.I.G.E.L / S.P.A.R.K.\nRAG + Claude
    }

    charm: C.H.A.R.M. {
      link: https://thecharmmodel.com
      tooltip: "React Native behavioral RPG"
      icon: https://icons.terrastruct.com/dev%2Freact.svg
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: C.H.A.R.M.\nReact Native RPG
    }

    ketaflix: Ketaflix {
      link: https://ketaflix-app.netlify.app
      tooltip: "Next.js 15 PWA, movie watchlist"
      icon: https://icons.terrastruct.com/dev%2Freact.svg
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Ketaflix\nNext.js 15 PWA
    }
  }

  warroom: WarRoom Agency {
    style.font-size: 36
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.bold: true
    style.shadow: true
    style.border-radius: 12

    execute: Execute Financial {
      tooltip: "Discord.js + Google Gemini, 13 agencies"
      icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Execute Financial\nDiscord.js + Gemini
    }

    warai: war-room-ai {
      tooltip: "Agency management + Google Gemini"
      icon: https://icons.terrastruct.com/dev%2Fnodejs.svg
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: war-room-ai\nAgency Mgmt + Gemini
    }

    leaderboard: Leaderboard Bot {
      tooltip: "Google Sheets integration, Railway"
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Leaderboard Bot\nSheets Integration
    }

    wrengine: WarRoomEngine {
      tooltip: "PostgreSQL admin engine"
      icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: WarRoomEngine\nPostgreSQL Admin
    }

    licbot: Licensing Bot {
      tooltip: "Recruit pipeline"
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
      style.bold: true
      style.shadow: true
      style.3d: true
      style.border-radius: 8
      label: Licensing Bot\nRecruit Pipeline
    }
  }
}

# ============================================================
# PAUSED (footnote-style, below the main layout)
# ============================================================

paused: Paused Projects {
  style.font-size: 28
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.bold: true
  style.border-radius: 12
  style.stroke-dash: 5

  novo: Novo Email Campaign {
    tooltip: "Paused — Resend + Gmail API, waiting on CSV + DNS"
    style.fill: "#EEEEEE"
    style.stroke: "#9E9E9E"
    style.bold: true
    style.border-radius: 8
    label: Novo Email Campaign\nResend + Gmail API
  }

  portfolio: Portfolio Site {
    tooltip: "Paused — not started"
    style.fill: "#EEEEEE"
    style.stroke: "#9E9E9E"
    style.bold: true
    style.border-radius: 8
  }
}

# ============================================================
# FOOTNOTE
# ============================================================

note: ||md
  All active projects use **GitHub** (spencer-life) + **Doppler** for secrets.
|| {
  style.font-size: 26
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  style.border-radius: 8
  style.bold: true
}

# ============================================================
# CONNECTIONS — color-coded by source project
# Left side approaches center from the left
# Right side approaches center from the right
# ============================================================

# Insurance AI (blue) → Supabase, Railway
col_l.insurance -> platform.supabase: {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
col_l.insurance -> platform.railway: {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}

# Submissions (red) → Netlify, Apps Script, Sheets
col_l.submissions -> platform.netlify: {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
col_l.submissions -> platform.apps_script: {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
col_l.submissions -> platform.sheets: {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

# Community (green) → Railway, Supabase, Netlify, Discord
col_r.community -> platform.supabase: {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
col_r.community -> platform.railway: {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
col_r.community -> platform.netlify: {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
col_r.community -> platform.discord_svc: {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}

# WarRoom (orange) → Railway, Discord, Sheets
col_r.warroom -> platform.railway: {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
col_r.warroom -> platform.discord_svc: {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
col_r.warroom -> platform.sheets: {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
