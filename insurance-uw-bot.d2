direction: down

vars: {
  svc: "#E8F0FE"
  db: "#E6F4EA"
  ext: "#FFF3E0"
  deploy: "#F3E8FF"
  discord: "#E8EAF6"
}

classes: {
  service: {
    style.fill: ${svc}
    style.stroke: "#1A73E8"
    style.bold: true
    style.shadow: true
    style.border-radius: 8
    style.font-size: 28
  }
  database: {
    shape: cylinder
    style.fill: ${db}
    style.stroke: "#34A853"
    style.bold: true
    style.shadow: true
    style.font-size: 28
  }
  external: {
    style.fill: ${ext}
    style.stroke: "#FF9800"
    style.stroke-dash: 3
    style.border-radius: 8
    style.font-size: 28
  }
  hosting: {
    shape: cloud
    style.fill: ${deploy}
    style.stroke: "#7C3AED"
    style.bold: true
    style.shadow: true
    style.font-size: 28
  }
  bot: {
    style.fill: ${discord}
    style.stroke: "#5865F2"
    style.bold: true
    style.shadow: true
    style.border-radius: 8
    style.font-size: 28
  }
}

# ── Discord Server ──
Discord: "Discord Server" {
  style.font-size: 32
  tooltip: "Multi-server underwriting bot"
  style.fill: "#F8F9FA"
  style.stroke: "#5865F2"
  style.border-radius: 12
  style.shadow: true

  User: "Agent / User" {
    shape: person
    style.fill: "#E8EAF6"
    style.stroke: "#5865F2"
  }

  Slash: "Slash Commands\n/case  /ask  /lookup\n/compare  /buildcheck" {
    class: bot
  }
}

# ── Bot Container ──
Bot: "Insurance UW Bot (Python)" {
  style.font-size: 32
  link: https://github.com/spencer-life/insurance-uw-bot
  icon: https://icons.terrastruct.com/dev%2Fpython.svg
  style.fill: "#F8F9FA"
  style.stroke: "#1A73E8"
  style.border-radius: 12
  style.shadow: true

  Agent: "Claude AI Agent\nSonnet 4 + Haiku 4.5" {
    class: service
  }

  Tools: "11 Agent Tools\nStructured Queries\nVector Search\nCarrier Selector" {
    class: service
  }
}

# ── Data Layer ──
Data: "Data Layer" {
  style.font-size: 32
  style.fill: "#F8F9FA"
  style.stroke: "#34A853"
  style.border-radius: 12
  style.shadow: true

  RailwayPG: "Railway PostgreSQL\n9 carriers, 32 products\n902 rules, 312 meds" {
    tooltip: "9 carriers, 32 products, 902 rules, 312 meds"
    class: database
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }

  SupaPG: "Supabase pgvector\nAlt Account\nGuideline Embeddings" {
    tooltip: "Alt account (schofieldspencer@gmail.com), guideline embeddings"
    class: database
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }

  OpenAI: "OpenAI Embeddings\ntext-embedding-3-small" {
    class: external
  }
}

# ── Deployment ──
Deploy: "Deployment" {
  style.font-size: 32
  style.fill: "#F8F9FA"
  style.stroke: "#7C3AED"
  style.border-radius: 12
  style.shadow: true

  Railway: "Railway\nAuto-deploy from GitHub" {
    link: https://railway.app
    class: hosting
    icon: https://icons.terrastruct.com/dev%2Fgithub.svg
  }

  Doppler: "Doppler\nspencer-main / dev_personal" {
    tooltip: "spencer-main/dev_personal config"
    class: service
    style.fill: "#F3E8FF"
  }
}

# ── Connections ──
Discord.User -> Discord.Slash: interacts
Discord.Slash -> Bot.Agent: triggers
Bot.Agent -> Bot.Tools
Bot.Tools -> Data.RailwayPG: queries
Bot.Tools -> Data.SupaPG: vector search
Data.OpenAI -> Data.SupaPG: generates embeddings
Deploy.Doppler -> Deploy.Railway: secrets
Deploy.Railway -> Bot: deploys
