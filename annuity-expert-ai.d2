direction: down

vars: {
  svc: "#E8F0FE"
  db: "#E6F4EA"
  ext: "#FFF3E0"
  deploy: "#F3E8FF"
  discord: "#E8EAF6"
}

classes: {
  service: {
    style.fill: ${svc}
    style.stroke: "#1A73E8"
    style.bold: true
    style.shadow: true
    style.border-radius: 8
    style.font-size: 18
  }
  database: {
    shape: cylinder
    style.fill: ${db}
    style.stroke: "#34A853"
    style.bold: true
    style.shadow: true
    style.font-size: 18
  }
  external: {
    style.fill: ${ext}
    style.stroke: "#FF9800"
    style.stroke-dash: 3
    style.border-radius: 8
    style.font-size: 18
  }
  hosting: {
    shape: cloud
    style.fill: ${deploy}
    style.stroke: "#7C3AED"
    style.bold: true
    style.shadow: true
    style.font-size: 18
  }
  bot: {
    style.fill: ${discord}
    style.stroke: "#5865F2"
    style.bold: true
    style.shadow: true
    style.border-radius: 8
    style.font-size: 18
  }
}

# ── Clients ──
Clients: "Clients" {
  style.font-size: 20
  style.fill: "#F8F9FA"
  style.stroke: "#5865F2"
  style.border-radius: 12
  style.shadow: true

  DiscordBot: "Discord Bot" {
    tooltip: "Slash command interface for agents"
    class: bot
  }

  WebUI: "Next.js Frontend\nNetlify" {
    link: https://annuity-expert-ai.netlify.app
    class: service
    icon: https://icons.terrastruct.com/dev%2Freact.svg
  }
}

# ── FastAPI Backend ──
Backend: "FastAPI Backend (Python)" {
  style.font-size: 20
  link: https://github.com/spencer-life/annuity-expert-ai
  icon: https://icons.terrastruct.com/dev%2Fpython.svg
  style.fill: "#F8F9FA"
  style.stroke: "#1A73E8"
  style.border-radius: 12
  style.shadow: true

  Agent: "Claude AI Agent\nSonnet 4 | 16 Tools" {
    class: service
  }

  Goals: "Goal Router\nIncome / Accumulation\nProtection / Legacy" {
    class: service
  }
}

# ── Data Layer ──
Data: "Data Layer" {
  style.font-size: 20
  style.fill: "#F8F9FA"
  style.stroke: "#34A853"
  style.border-radius: 12
  style.shadow: true

  RailwayPG: "Railway PostgreSQL\n19 carriers\nCrediting strategies\nMYGA rates" {
    tooltip: "19 carriers, crediting strategies, MYGA rates"
    class: database
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }

  SupaPG: "Supabase pgvector\nAlt Account" {
    tooltip: "Alt account, shared with UW Bot"
    class: database
    icon: https://icons.terrastruct.com/dev%2Fpostgresql.svg
  }
}

# ── External APIs ──
External: "External APIs" {
  style.font-size: 20
  style.fill: "#F8F9FA"
  style.stroke: "#FF9800"
  style.border-radius: 12
  style.shadow: true

  FRED: "FRED API\nEconomic Indicators" {
    link: https://fred.stlouisfed.org
    class: external
  }

  YFin: "yfinance\nMarket Data" {
    class: external
  }

  OpenAI: "OpenAI Embeddings\ntext-embedding-3-small" {
    class: external
  }
}

# ── Connections ──
Clients.DiscordBot -> Backend.Agent: commands
Clients.WebUI -> Backend.Agent: requests
Backend.Agent -> Backend.Goals: routes
Backend.Goals -> Data.RailwayPG: queries
Backend.Agent -> Data.SupaPG: vector search
Backend.Agent -> External.FRED: economic data
Backend.Agent -> External.YFin: market data
External.OpenAI -> Data.SupaPG: generates embeddings
